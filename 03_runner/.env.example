# ============================================================
#  API 配置 —— 复制本文件为 .env 后填入你自己的值
# ============================================================
#  本框架使用 OpenAI 兼容接口。
#
#  【最简用法】只填下面这组 LLM_* 变量，运行时用 --model default，
#  即可驱动任意 OpenAI 兼容端点（DeepSeek / OpenAI / GLM / 本地模型 / 网关）。
#
#  API key 去对应厂商控制台申请（一般在「API Keys / 密钥管理」页新建）：
#    DeepSeek → https://platform.deepseek.com/
#    OpenAI   → https://platform.openai.com/api-keys
#  key 等同密码，切勿提交进 git（.env 已被 .gitignore 排除）。

LLM_API_KEY=sk-xxx                          # 你的 API 密钥
LLM_BASE_URL=https://api.deepseek.com       # 端点地址（示例为 DeepSeek）
LLM_MODEL=deepseek-chat                     # 实际调用的模型名（填你厂商支持的标识）

# --- 改用 OpenAI，把上面三行换成： ---
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# ============================================================
#  多模型对照实验（进阶，用 --model 切换时才需要）
# ============================================================
#  若要用 --model 在 02_setting/models.json 注册的多个模型间切换，
#  按注册表里每个模型的 *_env 字段，额外配置对应变量。取消注释并填写：
#
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
#
# ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-opus-4-8
